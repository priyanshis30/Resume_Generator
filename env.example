# ── Copy this file to .env and fill in your values ──────────────────
# NEVER commit .env to GitHub — it is listed in .gitignore

# ── Gmail credentials (for sending notification emails) ─────────────
# Any Gmail you own. NOT the destination email — just the sender.
GMAIL_USER=your_sending_gmail@gmail.com

# Gmail App Password (16 chars, spaces OK)
# How: Google Account → Security → 2-Step Verification → App passwords
# Create app named "ResuméCraft" → copy the generated password
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Admin / download protection ──────────────────────────────────────
# Set this to any long random string. Used in the URL to protect:
#   /api/admin?token=...
#   /api/download-excel?token=...
#   /api/all-feedback?token=...
DOWNLOAD_TOKEN=change_me_to_something_very_secret_123

# ── Server port ──────────────────────────────────────────────────────
# Render sets PORT automatically. Leave 3001 for local dev.
PORT=3001
